{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "The Vantage Vault",
  "description": "An easy to navigate vault for documentation!",
  "colors": {
    "primary": "#008F64",
    "light": "#1EFFBC",
    "dark": "#008F64"
  },
  "favicon": {
    "light": "/images/VantageFavicon.svg",
    "dark": "/images/VantageFavicon.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "metadata": {
    "timestamp": true
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Onboarding",
        "groups": [
          {
            "group": "Welcome",
            "pages": ["index"]
          },
          {
            "group": "Your first days",
            "pages": []
          }
        ]
      },
      {
        "tab": "Case Studies",
        "pages": [
          "untitled-page",
          {
            "group": "Limited Product Line Shop",
            "pages": []
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/VantageFavicon.svg",
    "dark": "/images/VantageFavicon.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Submit IT ticket",
        "href": "/it-security/access-requests"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Employee portal",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  },
  "fonts": {
    "family": "Nunito"
  },
  "background": {
    "decoration": "windows"
  }
}
