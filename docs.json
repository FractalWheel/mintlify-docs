{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "The Vantage Vault",
  "description": "An easy to navigate vault for documentation!",
  "colors": {
    "primary": "#E56903",
    "light": "#DDFFF7",
    "dark": "#E56903"
  },
  "favicon": {
    "light": "/images/VantageFavicon.svg",
    "dark": "/images/VantageFavicon.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "metadata": {
    "timestamp": true
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Onboarding",
        "groups": [
          {
            "group": "Welcome",
            "pages": [
              "welcome-to-vantage-supply"
            ]
          }
        ]
      },
      {
        "tab": "Demos",
        "groups": [
          {
            "group": "Takumi",
            "pages": [
              "takumi-automotives",
              "art-direction",
              {
                "group": "Products",
                "pages": [
                  "shirts"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Code Snippets",
        "pages": [
          "start-here",
          {
            "group": "Footer",
            "pages": [
              "sticky-footer"
            ]
          },
          {
            "group": "GSAP",
            "pages": [
              "gsap-utils"
            ]
          },
          "text-logo-component",
          {
            "group": "Utilities",
            "pages": [
              "scroll"
            ]
          }
        ]
      },
      {
        "tab": "Vault",
        "groups": [
          {
            "group": "References",
            "pages": [
              "design",
              "web-dev-references"
            ]
          }
        ]
      },
      {
        "tab": "Orion",
        "pages": [
          {
            "group": "Specifications",
            "pages": [
              "current-capabilities"
            ]
          },
          {
            "group": "Shopify Guides",
            "pages": [
              "new-shop-quick-start",
              "production-deployments"
            ]
          },
          "welcome-to-orion"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/Property1=LightScreen.svg",
    "dark": "/images/Property1=DarkScreen.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Submit IT ticket",
        "href": "/it-security/access-requests"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Employee portal",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  },
  "fonts": {
    "family": "Geist"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#FEFEF7",
      "dark": "#080708"
    }
  }
}
